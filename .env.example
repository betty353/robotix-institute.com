# ─── Database ───────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/robotix_institute"

# ─── Auth (REQUIRED) ────────────────────────────────────────
# In production: must be at least 32 characters of random entropy.
# Generate with: openssl rand -base64 48
JWT_SECRET="change-me-to-a-long-random-string-min-32-chars-please"
JWT_EXPIRES_IN="7d"

# ─── App ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Robotix Institute"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ─── MQTT (IoT) ─────────────────────────────────────────────
# Server-side MQTT broker (mqtt:// or mqtts://)
MQTT_BROKER_URL="mqtt://localhost:1883"
# Client-side broker for browser (must be ws:// or wss://)
NEXT_PUBLIC_MQTT_BROKER_URL="ws://localhost:9001"
MQTT_USERNAME=""
MQTT_PASSWORD=""

# ─── AI Tutor (OpenAI compatible) ───────────────────────────
AI_API_KEY=""
AI_API_URL="https://api.openai.com/v1"
AI_MODEL="gpt-4o-mini"

# ─── File uploads ───────────────────────────────────────────
UPLOAD_DIR="./public/uploads"
MAX_FILE_SIZE_BYTES="10485760"   # 10 MB

# ─── Code execution backend (optional) ──────────────────────
# Self-hosted Judge0 / Piston URL for safe sandboxed multi-language exec
CODE_EXEC_URL=""
CODE_EXEC_API_KEY=""

# ─── Rate limiting (optional, for serverless deployments) ───
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
